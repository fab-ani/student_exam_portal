# defense in depth — folder-level .gitignores cover most of this,
# this catches anything that lands at the repo root.

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/
.next/
out/

# Env / secrets
.env
.env.local
.env.*.local

# Local databases
*.db
*.sqlite3

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
