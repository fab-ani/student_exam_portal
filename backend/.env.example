# Development defaults — copy to .env for local dev.
# In production, set these as environment variables in Render/Railway.

FLASK_ENV=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Required (and must not be a placeholder) when FLASK_ENV=production.
SECRET_KEY=dev-secret-key

# Local dev: SQLite is fine.
# Production: a managed Postgres URL (Render/Railway provide this).
DATABASE_URL=sqlite:///exam_portal.db

# Comma-separated list of allowed browser origins.
# Production: must be explicit (no wildcard).
# Example: https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000

# Local dev only — Render/Railway inject $PORT.
PORT=5000
